1.CREATE STACK
aws cloudformation create-stack \
  --stack-name eks-vpc-stack \
  --template-body file://vpc.yaml \
  --parameters \
    ParameterKey=AvailabilityZone1,ParameterValue=us-east-1a \
    ParameterKey=AvailabilityZone2,ParameterValue=us-east-1b \
  --profile my-user


note: in case error with credentials:
aws sts get-caller-identity --profile my-user

2.CHECK STATUS
 aws cloudformation describe-stacks \
                  --stack-name eks-vpc-stack \
                  --query "Stacks[0].StackStatus" \
                  --profile my-user

3. SEE IDs:
aws cloudformation describe-stacks \
    --stack-name eks-vpc-stack \
    --query "Stacks[0].Outputs" \
    --profile my-user

3. CREATE EKS cluster:
eksctl create cluster \
  --name springboot-eks \
  --version 1.30 \
  --region us-east-1 \
  --vpc-private-subnets subnet-08d9acc8c2b77f62a,subnet-03322781f282141a2 \
  --vpc-public-subnets subnet-0c4f7d7a87f4d5961,subnet-0f02bbf6966995d46 \
  --nodegroup-name springboot-nodes \
  --node-type t3.medium \
  --nodes 2 \
  --nodes-min 2 \
  --nodes-max 3 \
  --managed \
  --profile my-user


4. DELETE (reduce AWS payment)
Step 1: Delete the EKS cluster
eksctl delete cluster --name springboot-eks --region us-east-1 --profile my-user

Step 2: Delete the CloudFormation stack (VPC + subnets + NAT etc.)
aws cloudformation delete-stack --stack-name eks-vpc-stack  --profile my-user

5. In dir where Dockerfile
Build the Docker image locally
git checkout release
docker build -t spoonacular-app:1a62e50ec568f4332c00893d1c09a1065d74eaa8 .

6. Push your Docker image to a registry

# 1. Authenticate Docker with ECR
aws ecr get-login-password --region us-east-1 --profile my-user \
  | docker login --username AWS --password-stdin 270770993091.dkr.ecr.us-east-1.amazonaws.com

# 2. Create a repository (if not already)
aws ecr create-repository \
    --repository-name spoonacular-app \
    --profile my-user


# 3. Tag your image for ECR
docker tag spoonacular-app:1a62e50 270770993091.dkr.ecr.us-east-1.amazonaws.com/spoonacular-app:v1.0.0

# 4. Push the image
docker push 270770993091.dkr.ecr.us-east-1.amazonaws.com/spoonacular-app:v1.0.0

IN ORDER TO SAVE COSTS:
aws ecr delete-repository \
    --repository-name spoonacular-app \
    --force \
    --profile my-user

